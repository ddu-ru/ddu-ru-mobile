<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="25dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_height="wrap_content"
            android:layout_width="match_parent">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="게시글 작성하기"
                android:textColor="@color/title_text_black"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/cancel"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="right"
                android:text="취소"
                android:textSize="18sp"
                android:background="#00ff0000"
                android:textColor="@color/text_blue"
                android:stateListAnimator="@null"/>
        </androidx.appcompat.widget.Toolbar>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="여행 장소를 알려주세요(필수)"
            android:textColor="@color/content_text_black"
            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp" />

        <androidx.appcompat.widget.SearchView
            android:id="@+id/searchView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_border_defualt"
            android:stateListAnimator="@null"
            android:queryBackground="@null"
            android:layoutDirection="rtl"
            android:layout_marginTop="8dp"
            app:searchIcon="@drawable/ic_searchicon_custom_defualt"
            app:iconifiedByDefault="false"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="여행 날짜를 알려주세요(필수)"
            android:textColor="@color/content_text_black"
            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btnDepartureDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="출발일"
                android:textColor="@color/sub_gray"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_border_defualt"/>
            <Button
                android:id="@+id/btnArrivalDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="도착일"
                android:textColor="@color/sub_gray"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_border_defualt"/>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/calendarWrapper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:background="@drawable/bg_border_selected"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:elevation="4dp"
            android:padding="16dp">

            <com.kizitonwose.calendar.view.CalendarView
                android:id="@+id/calendarView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cv_dayViewResource="@layout/calendar_day_layout"
                app:cv_monthHeaderResource="@layout/calendar_month_header"
                app:cv_orientation="horizontal" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_horizontal"
            android:layout_marginTop="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="모집 인원을 알려주세요"
                android:gravity="center_vertical"
                android:textColor="@color/content_text_black"
                android:layout_gravity="start"
                android:layout_marginStart="16dp"/>

            <Spinner
                android:id="@+id/spinnerRecruit"
                android:layout_width="120dp"
                android:layout_height="45dp"
                android:dropDownWidth="match_parent"
                android:textColor="@color/sub_gray"
                android:background="@drawable/bg_border_defualt"
                android:layout_gravity="end"
                android:overlapAnchor="false"
                android:dropDownVerticalOffset="0dp"
                android:popupBackground="@drawable/bg_spinner_dropdown"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="모집 기간을 알려주세요"
                android:gravity="center_vertical"
                android:textColor="@color/content_text_black"
                android:layout_gravity="start"
                android:layout_marginStart="16dp"/>

            <Button
                android:id="@+id/btnRecruitDeadline"
                android:layout_width="120dp"
                android:layout_height="45dp"
                android:textColor="@color/sub_gray"
                android:background="@drawable/bg_border_defualt"
                android:layout_gravity="end"
                android:overlapAnchor="false"
                android:text="날짜선택"/>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="함께하고 싶은 성별을 알려주세요"
            android:textColor="@color/content_text_black"
            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="24dp">

            <Button
                android:id="@+id/btnMale"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="남성"
                android:textColor="@color/sub_gray"
                android:layout_weight="1"
                android:gravity="center"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_border_defualt"/>

            <Button
                android:id="@+id/btnFemale"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="여성"
                android:textColor="@color/sub_gray"
                android:layout_weight="1"
                android:gravity="center"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_border_defualt"/>

            <Button
                android:id="@+id/btnGenderAny"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="상관없음"
                android:textColor="@color/sub_gray"
                android:layout_weight="1"
                android:gravity="center"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_border_defualt"/>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="함께하고 싶은 연령대를 알려주세요"
            android:textColor="@color/content_text_black"
            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp"/>

<!--        <com.google.android.material.slider.RangeSlider-->
<!--            android:layout_width="match_parent"-->
<!--            android:layout_height="wrap_content"-->
<!--            />-->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="예상경비를 알려주세요"
            android:textColor="@color/content_text_black"
            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp"/>

<!--        <com.google.android.material.slider.RangeSlider-->
<!--            android:layout_width="match_parent"-->
<!--            android:layout_height="wrap_content"-->
<!--            />-->

        <Button
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="다음"
            android:textColor="@color/sub_gray"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:background="@drawable/bg_border_defualt"/>


    </LinearLayout>

</ScrollView>