<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/monthHeaderContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="10dp">

    <ImageButton
        android:id="@+id/btnPreviousMonth"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_month_back_button"
        android:scaleType="center"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Previous Month" />

    <TextView
        android:id="@+id/textMonth"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@android:color/black" />

    <TextView
        android:id="@+id/textYear"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@android:color/black" />

    <ImageButton
        android:id="@+id/btnNextMonth"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="8dp"
        android:src="@drawable/ic_month_next_button"
        android:scaleType="center"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Next Month" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/legendLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="4dp"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView android:id="@+id/legend1" style="@style/CalendarLegendText" android:text="Mo"/>
        <TextView android:id="@+id/legend2" style="@style/CalendarLegendText" android:text="Tu"/>
        <TextView android:id="@+id/legend3" style="@style/CalendarLegendText" android:text="We"/>
        <TextView android:id="@+id/legend4" style="@style/CalendarLegendText" android:text="Th"/>
        <TextView android:id="@+id/legend5" style="@style/CalendarLegendText" android:text="Fr"/>
        <TextView android:id="@+id/legend6" style="@style/CalendarLegendText" android:text="Sa"/>
        <TextView android:id="@+id/legend7" style="@style/CalendarLegendText" android:text="Su"/>
    </LinearLayout>

</LinearLayout>