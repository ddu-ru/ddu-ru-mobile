<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/label_access"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Access Token"
            android:textStyle="bold"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tv_access_token"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:textIsSelectable="true"
            android:autoLink="web"
            android:maxLines="6"
            android:ellipsize="end"
            android:text="(empty)" />

        <View
            android:layout_width="match_parent"
            android:layout_height="12dp" />

        <TextView
            android:id="@+id/label_refresh"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Refresh Token"
            android:textStyle="bold"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tv_refresh_token"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:textIsSelectable="true"
            android:autoLink="web"
            android:maxLines="6"
            android:ellipsize="end"
            android:text="(empty)" />
        <!-- 위 TextView 들 아래쪽에 추가 -->
        <Button
            android:id="@+id/btn_refresh_token"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Access Token 갱신" />

        <View
            android:layout_width="match_parent"
            android:layout_height="8dp" />

        <Button
            android:id="@+id/btn_logout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="로그아웃 요청" />

    </LinearLayout>
</ScrollView>
